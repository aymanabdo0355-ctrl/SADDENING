repeat task.wait() until game:IsLoaded()
task.wait()

local RS   = game:GetService("ReplicatedStorage")
local TP   = game:GetService("TeleportService")
local LP   = game:GetService("Players").LocalPlayer
local HS   = game:GetService("HttpService")
local SGui = game:GetService("StarterGui")

local function notify(msg, dur)
    pcall(function() SGui:SetCore("SendNotification", {Title = "Zero Hub", Text = msg, Duration = dur or 3}) end)
end

-- ── Single GC scan — grabs PlayerData, Actions, BannerData in one pass ──
local _pd, _actions
local _bannerNames, _bannerIdByName, _bannerCost, _bannerCurrency = {}, {}, {}, {}

local function scanPD()
    for _, obj in ipairs(getgc(true)) do
        if type(obj) == "table" and rawget(obj, "Token") == "PlayerData" and rawget(obj, "Data") and rawget(obj, "Data").ItemData then
            _pd = obj; return true
        end
    end
    return false
end

for _, obj in ipairs(getgc(true)) do
    if type(obj) == "table" then
        if not _pd and rawget(obj, "Token") == "PlayerData" and rawget(obj, "Data") and rawget(obj, "Data").ItemData then
            _pd = obj
        end
        if not _actions and type(rawget(obj, "Summon")) == "function" and type(rawget(obj, "RerollTrait")) == "function" then
            _actions = obj
        end
        if rawget(obj, "Token") == "BannerData" and rawget(obj, "Data") then
            local d = obj.Data
            if d.BannerID and d.BannerInfo then
                local name = d.BannerInfo.Styling and d.BannerInfo.Styling.Name or d.BannerID
                local cost = d.BannerInfo.Cost or 0
                local cur  = d.BannerInfo.Currency or "Gem"
                local label = name .. " (" .. cur .. " x" .. cost .. ")"
                _bannerNames[#_bannerNames + 1] = label
                _bannerIdByName[label] = d.BannerID
                _bannerCost[d.BannerID] = cost
                _bannerCurrency[d.BannerID] = cur
            end
        end
    end
end

if not _pd then repeat task.wait() until scanPD() end

table.sort(_bannerNames)
if #_bannerNames == 0 then _bannerNames = {"No banners"} end

local _nodes = nil
pcall(function() _nodes = require(RS:WaitForChild("Nodes", 5)) end)
local _info = nil
pcall(function() _info = require(RS:WaitForChild("Shared", 5):WaitForChild("Information", 5)) end)

-- ── Progress persistence ──
local PROG_PATH = "ZeroHub/AnimeExpeditions/rollback_progress.json"
pcall(function()
    if not isfolder("ZeroHub") then makefolder("ZeroHub") end
    if not isfolder("ZeroHub/AnimeExpeditions") then makefolder("ZeroHub/AnimeExpeditions") end
end)

local function loadProgress()
    if not isfile(PROG_PATH) then return {} end
    local ok, d = pcall(HS.JSONDecode, HS, readfile(PROG_PATH))
    return ok and d or {}
end
local function saveProgress(t) pcall(function() writefile(PROG_PATH, HS:JSONEncode(t)) end) end
local prog = loadProgress()

-- ── Helpers ──
local function rollback()
    pcall(function()
        RS.Nodes.Network.NetworkEvents._updateNode:FireServer(
            {Type = "Post"}, "CLIENT_CHANGE_SETTING", "StatFiltering", {["\255"] = {S = true}}
        )
    end)
    task.wait(0.5)
    TP:Teleport(game.PlaceId, LP)
end

local function freshPD()
    scanPD()
    return _pd
end

local function getUnitData()
    if _pd and _pd.Data and _pd.Data.UnitData then return _pd.Data.UnitData end
    scanPD()
    return _pd and _pd.Data and _pd.Data.UnitData or {}
end

local function getCurrency(name)
    if _pd and _pd.Data and _pd.Data.ItemData then
        local v = _pd.Data.ItemData[name]
        if v then return type(v) == "table" and v.Amount or v end
    end
    scanPD()
    if _pd and _pd.Data and _pd.Data.ItemData then
        local v = _pd.Data.ItemData[name]
        if v then return type(v) == "table" and v.Amount or v end
    end
    return 0
end

local function doSummon(bannerId, batch)
    if not _actions or not _actions.Summon then return false end
    local fn = _actions.Summon
    local origUp = debug.getupvalue(fn, 1)
    local node = _nodes and _nodes.BANNER_SUMMON
    if node then debug.setupvalue(fn, 1, {BANNER_SUMMON = node}) end
    local ok = pcall(fn, bannerId, batch or 10)
    if origUp then debug.setupvalue(fn, 1, origUp) end
    return ok
end

local function doRerollTrait(uid)
    if not _actions or not _actions.RerollTrait then return false end
    local fn = _actions.RerollTrait
    local origUp = debug.getupvalue(fn, 1)
    local node = _nodes and _nodes.ROLL_UNIT_TRAIT
    if node then debug.setupvalue(fn, 1, {ROLL_UNIT_TRAIT = node}) end
    local ok = pcall(fn, uid, true)
    if origUp then debug.setupvalue(fn, 1, origUp) end
    return ok
end

-- ── Unit & trait lists ──
local _allUnitNames = {}
if _info and _info.Units then
    for k in pairs(_info.Units) do
        if not k:match("EVO$") and not k:match("Spirit$") and not k:match("Wolf$") then
            _allUnitNames[#_allUnitNames + 1] = k
        end
    end
end
table.sort(_allUnitNames)

local _ownedUnits, _ownedIdMap = {}, {}
do
    local dupes = {}
    for uid, unit in pairs(getUnitData()) do
        if type(unit) == "table" and unit.Asset then
            local rarity = ""
            if _info and _info.Units and _info.Units[unit.Asset] then
                rarity = _info.Units[unit.Asset].Rarity or ""
            end
            local trait = unit.Trait or "no trait"
            local base = unit.Asset
            dupes[base] = (dupes[base] or 0) + 1
            if dupes[base] > 1 then base = base .. " #" .. dupes[base] end
            local label = base .. " [" .. rarity .. "] " .. trait
            _ownedUnits[#_ownedUnits + 1] = label
            _ownedIdMap[label] = uid
        end
    end
    table.sort(_ownedUnits)
end

local _traitNames = {
    "Primordial","Forsaken","Unbound","Draconic","Limit Breaker","Investor",
    "Bolt","Optics","Precision 1","Precision 2","Enlightenment",
    "Range 1","Range 2","Speed 1","Speed 2","Strength 1","Strength 2"
}

-- ── Core loops ──
local function runSummonRollback(bannerId, targetUnits, batchSize)
    if not bannerId or not targetUnits or not next(targetUnits) then
        notify("Pick a banner and target units"); return
    end
    local cost = _bannerCost[bannerId] or 50
    local currency = _bannerCurrency[bannerId] or "Gem"
    local total = 0
    local before = {}
    for uid in pairs(getUnitData()) do before[uid] = true end

    while true do
        local bal = getCurrency(currency)
        local batch = math.min(batchSize, math.floor(bal / (cost > 0 and cost or 1)))
        if batch < 1 then
            notify("Out of " .. currency .. " after " .. total .. " summons", 4)
            prog = {inProgress = true, mode = "summon", bannerId = bannerId, targetUnits = targetUnits, batchSize = batchSize}
            saveProgress(prog)
            task.wait(1); rollback(); return
        end

        doSummon(bannerId, batch)
        total = total + batch
        task.wait(0.3)

        local newNames = {}
        for uid, unit in pairs(getUnitData()) do
            if not before[uid] and type(unit) == "table" then
                newNames[#newNames + 1] = unit.Asset or "?"
                before[uid] = true
                if targetUnits[unit.Asset] then
                    prog.inProgress = false; saveProgress(prog)
                    LP:Kick("GOT " .. unit.Asset .. " after " .. total .. " summons!")
                    return
                end
            end
        end

        if total >= 1000 then
            notify("1000 summons, no target — rolling back", 4)
            prog = {inProgress = true, mode = "summon", bannerId = bannerId, targetUnits = targetUnits, batchSize = batchSize}
            saveProgress(prog)
            task.wait(0.5); rollback(); return
        end
        if total % 50 == 0 or #newNames > 0 then
            notify("Summoned " .. total .. (#newNames > 0 and ("\nGot: " .. table.concat(newNames, ", ")) or ""), 4)
        end
        task.wait()
    end
end

local function readTrait(uid)
    -- Fast path: direct read off cached _pd
    if _pd and _pd.Data and _pd.Data.UnitData then
        local unit = _pd.Data.UnitData[uid]
        if unit and unit.Trait then return unit.Trait end
    end
    -- Stale reference — one targeted re-scan
    scanPD()
    if _pd and _pd.Data and _pd.Data.UnitData then
        local unit = _pd.Data.UnitData[uid]
        if unit then return unit.Trait end
    end
    return nil
end

local function readRerollCount()
    if _pd and _pd.Data and _pd.Data.ItemData then
        local v = _pd.Data.ItemData.TraitReroll
        if v then return type(v) == "table" and v.Amount or v end
    end
    return 0
end

local function runTraitRollback(uid, targetTraits)
    if not uid or not targetTraits or not next(targetTraits) then
        notify("Pick a unit and target traits"); return
    end
    for i = 1, 200 do
        if i % 10 == 1 and readRerollCount() < 1 then
            notify("Out of trait rerolls after " .. (i - 1) .. " rolls", 4)
            prog = {inProgress = true, mode = "trait", traitUid = uid, traitTargets = targetTraits}
            saveProgress(prog)
            task.wait(0.5); rollback(); return
        end

        doRerollTrait(uid)
        task.wait(0.15)

        local gotTrait = readTrait(uid)
        if gotTrait and targetTraits[gotTrait] then
            prog.inProgress = false; saveProgress(prog)
            LP:Kick("GOT " .. gotTrait .. " after " .. i .. " rolls!")
            return
        end
        if i % 50 == 0 then
            notify("Rerolled " .. i .. "x (got: " .. (gotTrait or "none") .. ")", 2)
        end
    end

    notify("200 rerolls — rolling back", 4)
    prog = {inProgress = true, mode = "trait", traitUid = uid, traitTargets = targetTraits}
    saveProgress(prog)
    task.wait(0.5); rollback()
end

