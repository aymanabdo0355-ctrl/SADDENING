Library:CreateSettingsTab(Window)

-- ── Auto-resume if mid-rollback ──
task.defer(function()
    -- Wait until PlayerData is actually loaded with real data
    for i = 1, 60 do
        if _pd and _pd.Data and _pd.Data.ItemData and next(_pd.Data.ItemData) then break end
        -- Re-scan if needed
        if i % 10 == 0 then
            for _, obj in ipairs(getgc(true)) do
                if type(obj) == "table" and rawget(obj, "Token") == "PlayerData" and rawget(obj, "Data") then
                    _pd = obj; break
                end
            end
        end
        task.wait(1)
    end
    if not _pd or not _pd.Data or not _pd.Data.ItemData then return end

    if not prog.inProgress then return end
    -- Wait for full game load — character exists and PlayerData has items
    while not (LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")) do task.wait(1) end
    while not (_pd and _pd.Data and _pd.Data.ItemData and next(_pd.Data.ItemData)) do
        for _, obj in ipairs(getgc(true)) do
            if type(obj) == "table" and rawget(obj, "Token") == "PlayerData" and rawget(obj, "Data") and rawget(obj, "Data").ItemData then
                _pd = obj; break
            end
        end
        task.wait(1)
    end
    task.wait(3)
    if prog.mode == "summon" and prog.bannerId and prog.targetUnits and next(prog.targetUnits) then
        notify("Resuming rollback summon...", 3)
        task.wait(2)
        runSummonRollback(prog.bannerId, prog.targetUnits, prog.batchSize or 10)
    elseif prog.mode == "trait" and prog.traitUid and prog.traitTargets and next(prog.traitTargets) then
        notify("Resuming rollback trait reroll...", 3)
        task.wait(2)
        runTraitRollback(prog.traitUid, prog.traitTargets)
    else
        prog.inProgress = false; saveProgress(prog)
    end
end)
