Library:CreateSettingsTab(Window)

-- ── Auto-resume ──
task.defer(function()
    if not prog.inProgress then return end

    -- Wait for character + full game state
    while not (LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")) do task.wait(1) end
    task.wait(2)

    -- Re-acquire everything — old refs are dead after teleport
    for attempt = 1, 30 do
        scanPD()
        if not _actions then
            for _, obj in ipairs(getgc(true)) do
                if type(obj) == "table" and type(rawget(obj, "Summon")) == "function" and type(rawget(obj, "RerollTrait")) == "function" then
                    _actions = obj; break
                end
            end
        end
        pcall(function() _nodes = require(RS:WaitForChild("Nodes", 5)) end)
        if _pd and _actions and _nodes then break end
        task.wait(1)
    end

    if not _pd or not _actions then
        notify("Resume failed — couldn't find game data", 4)
        prog.inProgress = false; saveProgress(prog)
        return
    end

    -- Wait for ItemData to actually populate
    for _ = 1, 30 do
        if _pd.Data and _pd.Data.ItemData and next(_pd.Data.ItemData) then break end
        scanPD()
        task.wait(1)
    end

    task.wait(1)
    if prog.mode == "summon" and prog.bannerId and prog.targetUnits and next(prog.targetUnits) then
        notify("Resuming rollback summon...", 3)
        task.wait(2)
        runSummonRollback(prog.bannerId, prog.targetUnits, prog.batchSize or 10)
    elseif prog.mode == "trait" and prog.traitUid and prog.traitTargets and next(prog.traitTargets) then
        notify("Resuming rollback trait reroll...", 3)
        task.wait(2)
        runTraitRollback(prog.traitUid, prog.traitTargets)
    else
        prog.inProgress = false; saveProgress(prog)
    end
end)
