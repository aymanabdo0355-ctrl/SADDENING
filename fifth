repeat task.wait() until game:IsLoaded()
task.wait(1)

local RS = game:GetService("ReplicatedStorage")
local TP = game:GetService("TeleportService")
local LP = game:GetService("Players").LocalPlayer

local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/toeerolo-z/ethossuiterewrite/refs/heads/main/ethossuite.lua"))()
local Window = Library:CreateWindow({ Title = "Zero Hub - Rollback", Version = "v3.0" })
local Box = Window:AddCategory("MAIN"):AddTab("Rollback"):AddGroupbox("Rollback")

Box:AddButton({
    Text = "Rollback",
    Func = function()
        pcall(function()
            RS.Nodes.Network.NetworkEvents._updateNode:FireServer(
                {Type = "Post"}, "CLIENT_CHANGE_SETTING", "StatFiltering", {["\255"] = {S = true}}
            )
        end)
        task.wait(0.5)
        TP:Teleport(game.PlaceId, LP)
    end,
})
